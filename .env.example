# Database
DATABASE_URL=postgresql://ecolink:ecolink_dev_pass@localhost:5432/ecolink
POSTGRES_DB=ecolink
POSTGRES_USER=ecolink
POSTGRES_PASSWORD=ecolink_dev_pass

# Redis
REDIS_URL=redis://:redis_dev_pass@localhost:6379
REDIS_PASSWORD=redis_dev_pass

# JWT
JWT_ACCESS_SECRET=change_this_to_64_random_chars_minimum_in_production
JWT_REFRESH_SECRET=change_this_to_another_64_random_chars_for_refresh
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Google AI (Gemini)
GEMINI_API_KEY=your_google_ai_api_key_here

# Google OAuth
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# MinIO (Object Storage)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=ecolink
MINIO_USE_SSL=false

# Email (Mailhog for dev)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@ecolink.app
SMTP_USER=
SMTP_PASS=

# App
FRONTEND_URL=http://localhost:3000
PORT=4000
NODE_ENV=development
